rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: id, nome, telefone, tipo (cliente/admin), createdAt
    //
    // Collection: services
    // Fields: id, nome, categoria, preco, ativo
    //
    // Collection: appointments
    // Fields: id, userId, userName, userPhone, serviceId, serviceName, servicePrice, data, hora, status, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipo == 'admin' ||
         request.auth.token.email == "madoff235@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'nome', 'telefone', 'tipo']) &&
             data.nome is string && data.nome.size() > 0 && data.nome.size() < 100 &&
             data.telefone is string &&
             data.tipo in ['cliente', 'admin'];
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['userId', 'serviceId', 'data', 'hora', 'status']) &&
             data.data.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.hora.matches("^\\d{2}:\\d{2}$") &&
             data.status in ['pendente', 'confirmado', 'cancelado'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.tipo == resource.data.tipo);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /appointments/{appointmentId} {
      // Allow authenticated users to list appointments for availability check
      // In a real app, we would use a more restrictive query or a separate collection
      allow list: if isAuthenticated();
      allow get: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidAppointment(request.resource.data)) || 
                    (request.resource.data.userId == 'guest' && isValidAppointment(request.resource.data));
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.status == 'cancelado');
      allow delete: if isAdmin();
    }
  }
}
